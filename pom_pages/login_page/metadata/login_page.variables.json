{
  "pageName": "login_page",
  "pageUrl": "https://opensource-demo.orangehrmlive.com/web/index.php/auth/login",
  "variables": [
    {
      "variableName": "PAGE_URL",
      "value": "https://opensource-demo.orangehrmlive.com/web/index.php/auth/login",
      "source": "approved_page",
      "kind": "page_url"
    },
    {
      "variableName": "LOGIN_PAGE_TITLE",
      "value": "xpath=//h5[normalize-space()='Login']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "login_page_title",
      "type": "label"
    },
    {
      "variableName": "USERNAME_TEXTBOX",
      "value": "xpath=//input[@name='username']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "username_textbox",
      "type": "textbox"
    },
    {
      "variableName": "PASSWORD_TEXTBOX",
      "value": "xpath=//input[@name='password']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "password_textbox",
      "type": "password"
    },
    {
      "variableName": "LOGIN_BUTTON",
      "value": "xpath=//button[@type='submit']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "login_button",
      "type": "button"
    },
    {
      "variableName": "FORGOT_PASSWORD_LINK",
      "value": "xpath=//p[normalize-space()='Forgot your password?']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "forgot_password_link",
      "type": "link"
    },
    {
      "variableName": "INVALID_CREDENTIALS_MESSAGE",
      "value": "xpath=//p[normalize-space()='Invalid credentials']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "invalid_credentials_message",
      "type": "message"
    },
    {
      "variableName": "REQUIRED_FIELD_MESSAGE",
      "value": "xpath=//span[normalize-space()='Required']",
      "source": "approved_element",
      "kind": "locator",
      "approvedName": "required_field_message",
      "type": "message"
    }
  ]
}