  "reviewSummary": {
    "overall_quality": "medium",
    "summary": "The draft captures the primary login controls but includes multiple noisy container elements, weak generic locators, poor semantic naming, and misses important validation message elements required for negative authentication scenarios.",
    "issues": [
      {
        "severity": "high",
        "type": "naming",
        "element_name": "password",
        "message": "Element name is too generic and inconsistent with the established semantic naming convention used for other form fields.",
        "suggested_fix": "Rename to password_textbox."
      },
      {
        "severity": "high",
        "type": "classification",
        "element_name": "password",
        "message": "Password input is classified as textbox instead of a password field.",
        "suggested_fix": "Change type from textbox to password."
      },
      {
        "severity": "critical",
        "type": "locator",
        "element_name": "element_5",
        "message": "Locator xpath=//a is overly generic and likely to match multiple links on the page.",
        "suggested_fix": "Remove this element because it is non-semantic and duplicates other link coverage."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "forgot_your_password",
        "message": "Locator xpath=//p is overly generic and may match multiple paragraph elements.",
        "suggested_fix": "Use xpath=//p[normalize-space()='Forgot your password?'] and rename to forgot_password_link."
      },
      {
        "severity": "high",
        "type": "classification",
        "element_name": "forgot_your_password",
        "message": "Forgot password control is classified as a generic element instead of a navigational link.",
        "suggested_fix": "Change type to link."
      },
      {
        "severity": "medium",
        "type": "locator",
        "element_name": "username_textbox",
        "message": "Locator based only on placeholder text may be less stable than attribute-based identification.",
        "suggested_fix": "Prefer xpath=//input[@name='username']."
      },
      {
        "severity": "medium",
        "type": "locator",
        "element_name": "password",
        "message": "Locator based only on placeholder text may be less stable than attribute-based identification.",
        "suggested_fix": "Prefer xpath=//input[@name='password']."
      },
      {
        "severity": "medium",
        "type": "locator",
        "element_name": "login_button",
        "message": "Locator depends on visible text and may be affected by localization or text changes.",
        "suggested_fix": "Prefer xpath=//button[@type='submit']."
      },
      {
        "severity": "high",
        "type": "noise",
        "element_name": "login_username_admin_password_admin123_username_password_login_forgot_your_password_orangehrm_os_5_9_2005_2026_orangehrm_inc_all_rights_reserved",
        "message": "Large page container element is noisy, non-actionable, and unsuitable for reusable automation.",
        "suggested_fix": "Remove this element entirely."
      },
      {
        "severity": "high",
        "type": "duplicate",
        "element_name": "login_username_admin_password_admin123_username_password_login_forgot_your_password_orangehrm_os_5_9_2005_2026_orangehrm_inc_all_rights_reserved",
        "message": "Duplicate container-style elements represent the same page wrapper and add unnecessary noise.",
        "suggested_fix": "Remove duplicate wrapper/container elements."
      },
      {
        "severity": "medium",
        "type": "noise",
        "element_name": "username",
        "message": "Standalone username label provides limited automation value because the textbox already sufficiently identifies the field.",
        "suggested_fix": "Remove unless explicit label verification is required."
      },
      {
        "severity": "medium",
        "type": "locator",
        "element_name": "username",
        "message": "Locator xpath=//label is overly generic and may match unrelated labels.",
        "suggested_fix": "Use a text-qualified locator or remove the element."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "login",
        "message": "Element name is too generic and does not clearly represent the page title purpose.",
        "suggested_fix": "Rename to login_page_title."
      },
      {
        "severity": "medium",
        "type": "classification",
        "element_name": "login",
        "message": "Login page title is classified as a generic element instead of a label or heading.",
        "suggested_fix": "Change type to label."
      },
      {
        "severity": "medium",
        "type": "locator",
        "element_name": "login",
        "message": "Locator xpath=//h5 is too generic and may match other headings.",
        "suggested_fix": "Use xpath=//h5[normalize-space()='Login']."
      },
      {
        "severity": "low",
        "type": "noise",
        "element_name": "orangehrm_inc_link",
        "message": "Branding footer link is low business priority for authentication workflow automation.",
        "suggested_fix": "Remove unless external branding-link validation is required."
      },
      {
        "severity": "critical",
        "type": "validation_gap",
        "element_name": "",
        "message": "Invalid credentials message element required for negative authentication validation is missing from the approved draft elements.",
        "suggested_fix": "Add invalid_credentials_message with locator xpath=//p[normalize-space()='Invalid credentials']."
      },
      {
        "severity": "critical",
        "type": "validation_gap",
