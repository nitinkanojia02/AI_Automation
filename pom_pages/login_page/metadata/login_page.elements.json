  "reviewSummary": {
    "overall_quality": "medium",
    "summary": "The draft captures core login controls but contains significant noise, weak generic locators, poor semantic naming, and missing validation elements needed for reliable downstream automation.",
    "issues": [
      {
        "severity": "high",
        "type": "naming",
        "element_name": "password",
        "message": "Element name is too generic and does not clearly identify the control type or business purpose.",
        "suggested_fix": "Rename to 'password_textbox' and classify as type 'password'."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "element_5",
        "message": "Locator 'xpath=//a' is overly generic and likely to match multiple elements.",
        "suggested_fix": "Remove this element because it represents a decorative social-media link not required for workflow automation."
      },
      {
        "severity": "high",
        "type": "noise",
        "element_name": "orangehrm_inc_link",
        "message": "Branding/footer link is not relevant to login workflow automation and adds unnecessary noise.",
        "suggested_fix": "Remove the branding link from approved elements."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "forgot_your_password",
        "message": "Locator 'xpath=//p' is overly generic and unreliable for automation.",
        "suggested_fix": "Use a semantic name like 'forgot_password_link' with locator 'xpath=//p[normalize-space()='Forgot your password?']'."
      },
      {
        "severity": "high",
        "type": "classification",
        "element_name": "forgot_your_password",
        "message": "Element classified as generic 'element' even though it behaves as a navigational link.",
        "suggested_fix": "Classify as type 'link'."
      },
      {
        "severity": "critical",
        "type": "noise",
        "element_name": "login_username_admin_password_admin123_username_password_login_forgot_your_password_orangehrm_os_5_9_2005_2026_orangehrm_inc_all_rights_reserved",
        "message": "Massive container text aggregation element is unusable for downstream automation and creates unstable page models.",
        "suggested_fix": "Remove all aggregated container elements and retain only meaningful actionable controls."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "username",
        "message": "Locator 'xpath=//label' is too generic and may match multiple labels.",
        "suggested_fix": "Either remove this duplicate label element or use a scoped locator such as 'xpath=//label[normalize-space()='Username']'."
      },
      {
        "severity": "medium",
        "type": "duplicate",
        "element_name": "username",
        "message": "Username label duplicates the username textbox purpose and provides limited additional automation value.",
        "suggested_fix": "Remove the label unless explicit label verification is required."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "login",
        "message": "Element name is ambiguous and does not communicate that this is the page title.",
        "suggested_fix": "Rename to 'login_page_title'."
      },
      {
        "severity": "medium",
        "type": "classification",
        "element_name": "login",
        "message": "Page title is classified as generic 'element' instead of a meaningful label/title type.",
        "suggested_fix": "Classify as type 'label' or 'heading'."
      },
      {
        "severity": "medium",
        "type": "locator",
        "element_name": "login",
        "message": "Locator 'xpath=//h5' is weak and may become unstable if additional headings appear.",
        "suggested_fix": "Use 'xpath=//h5[normalize-space()='Login']'."
      },
      {
        "severity": "critical",
        "type": "validation_gap",
        "element_name": "",
        "message": "No explicit invalid credentials message element exists even though failed authentication validation is a major workflow requirement.",
        "suggested_fix": "Add an 'invalid_credentials_message' element with a stable text-based locator."
      },
      {
        "severity": "high",
        "type": "validation_gap",
        "element_name": "",
        "message": "Required field validation message element is missing despite mandatory-field scenarios in approved tests.",
        "suggested_fix": "Add a reusable 'required_field_message' validation element."
      }
    ],
