  "reviewSummary": {
    "overall_quality": "medium",
    "summary": "The draft captures the primary guest-state navigation controls required for the Home workflow, but several approved element names are overly technical, and the artifact includes noisy duplicate/layout elements that reduce downstream automation quality.",
    "issues": [
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_person_btn_button",
        "message": "Element name is technical and derived from DOM id instead of business intent.",
        "suggested_fix": "Rename to Person Profile Button for clearer downstream keyword and test generation."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_back_btn_button",
        "message": "Element name exposes implementation details instead of user-facing intent.",
        "suggested_fix": "Rename to Back Button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_notification_btn_button",
        "message": "Element name is DOM-centric and not business-readable.",
        "suggested_fix": "Rename to Notification Button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_home_btn_button",
        "message": "Element name is technical and redundant.",
        "suggested_fix": "Rename to Home Button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_btn_customersignup_button",
        "message": "Element name is difficult to read and tightly coupled to implementation naming.",
        "suggested_fix": "Rename to Customer Signup Button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_btn_cleansurvey_button",
        "message": "Element name is implementation-centric rather than workflow-centric.",
        "suggested_fix": "Rename to Clean Survey Button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "auto_btn_sitesurvey_button",
        "message": "Element name is implementation-centric rather than business-readable.",
        "suggested_fix": "Rename to Site Survey Button."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "element_8",
        "message": "Locator xpath=//a is overly generic and likely to match multiple links, creating unstable automation behavior.",
        "suggested_fix": "Remove this duplicate wrapper element and rely on the existing Home Button element with id=auto_home_btn."
      },
      {
        "severity": "high",
        "type": "duplicate",
        "element_name": "element_8",
        "message": "This link appears to be the internal anchor rendered inside the Home button shadow DOM and duplicates the Home button control already captured.",
        "suggested_fix": "Remove the duplicate link element from the approved page model."
      },
      {
        "severity": "medium",
        "type": "noise",
        "element_name": "background_content_element",
        "message": "Background content container is layout-only and does not provide meaningful workflow interaction or validation value.",
        "suggested_fix": "Remove the background container from approved elements."
      },
      {
        "severity": "low",
        "type": "validation_gap",
        "element_name": "",
        "message": "No explicit page-state indicator or guest-state identifier element is captured beyond navigation controls and URL validation.",
        "suggested_fix": "If available in the UI, capture a stable guest-state page identifier or header element to strengthen non-URL page verification."
      }
    ],
