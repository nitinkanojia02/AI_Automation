  "reviewSummary": {
    "overall_quality": "medium",
    "summary": "The draft captures the core guest-state controls required for the Home workflow, but contains weak naming, duplicate wrapper artifacts, and noisy non-actionable elements that would reduce downstream automation quality.",
    "issues": [
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "person_button",
        "message": "The element name is too generic and loses the business meaning defined in the workflow.",
        "suggested_fix": "Rename to 'person_profile_button' to align with workflow terminology and downstream resource ownership guidance."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "customersignup_button",
        "message": "The element name is compressed and not human-friendly for automation readability.",
        "suggested_fix": "Rename to 'customer_signup_button'."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "cleansurvey_button",
        "message": "The element name lacks readable word separation and business clarity.",
        "suggested_fix": "Rename to 'clean_survey_button'."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "sitesurvey_button",
        "message": "The element name lacks readable word separation and business clarity.",
        "suggested_fix": "Rename to 'site_survey_button'."
      },
      {
        "severity": "high",
        "type": "duplicate",
        "element_name": "element_8",
        "message": "This generic anchor element is a duplicate wrapper representation of the Home button and uses an overly broad locator.",
        "suggested_fix": "Remove this element and keep the dedicated 'home_button' element with locator 'id=auto_home_btn'."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "element_8",
        "message": "The locator 'xpath=//a' is extremely generic and likely to match multiple links.",
        "suggested_fix": "Remove the element entirely because the workflow already has a stable Home button locator."
      },
      {
        "severity": "medium",
        "type": "noise",
        "element_name": "background_content",
        "message": "This is a layout/background container with no business interaction or validation value for the workflow.",
        "suggested_fix": "Remove the element from the approved page model."
      },
      {
        "severity": "medium",
        "type": "validation_gap",
        "element_name": "",
        "message": "The workflow explicitly requires validation that authenticated-only controls and the logged-in user name button are absent, but no observable element candidates are present to support negative-state verification.",
        "suggested_fix": "Capture any authenticated-only menu, profile-name display, or logged-in identity indicator elements if available in the UI."
      },
      {
        "severity": "low",
        "type": "classification",
        "element_name": "home_button",
        "message": "The underlying native control appears to be rendered as a link anchor inside an ion-button wrapper.",
        "suggested_fix": "Keeping the element classified as a button is acceptable for workflow semantics, but downstream tooling should recognize it may navigate via anchor behavior."
      }
    ],
