  "reviewSummary": {
    "overall_quality": "medium",
    "summary": "The draft captures the core guest-state navigation controls required for the Home workflow, but it contains noisy non-business elements, weak generic locators, and naming issues that reduce downstream automation quality. Important negative-validation elements for unauthenticated state verification are also missing.",
    "issues": [
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "person_button",
        "message": "The element name is too generic and does not preserve the business meaning of the Person/Profile control used throughout the workflow.",
        "suggested_fix": "Rename to person_profile_button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "customersignup_button",
        "message": "The element name is compressed and less readable for downstream automation and keyword generation.",
        "suggested_fix": "Rename to customer_signup_button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "cleansurvey_button",
        "message": "The element name lacks readable business separation and reduces keyword clarity.",
        "suggested_fix": "Rename to clean_survey_button."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "sitesurvey_button",
        "message": "The element name lacks readable business separation and reduces keyword clarity.",
        "suggested_fix": "Rename to site_survey_button."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "element_8",
        "message": "The locator xpath=//a is overly generic, brittle, and likely to match multiple links on the page.",
        "suggested_fix": "Remove this duplicate wrapper element and rely on the existing semantic home_button element with locator id=auto_home_btn."
      },
      {
        "severity": "high",
        "type": "noise",
        "element_name": "element_8",
        "message": "This appears to be an internal native anchor wrapper for the Home button rather than a separate business control.",
        "suggested_fix": "Remove the duplicate wrapper element from the approved page model."
      },
      {
        "severity": "medium",
        "type": "noise",
        "element_name": "background_content",
        "message": "The background-content container is decorative layout infrastructure and not meaningful for workflow automation.",
        "suggested_fix": "Remove the background_content element from the approved page model."
      },
      {
        "severity": "high",
        "type": "validation_gap",
        "element_name": "",
        "message": "The workflow explicitly requires validation that the logged-in user name button is not visible in guest state, but no corresponding observable element or validation target exists in the artifact.",
        "suggested_fix": "Add a semantic element representing the logged-in user indicator or authenticated user name button if it exists in the DOM."
      },
      {
        "severity": "high",
        "type": "validation_gap",
        "element_name": "",
        "message": "The workflow requires validation that authenticated-only controls and feature buttons are absent or non-actionable in guest state, but no authenticated-only controls are represented in the artifact.",
        "suggested_fix": "Add observable authenticated-only controls or state indicators needed for negative guest-state validation."
      },
      {
        "severity": "medium",
        "type": "missing_element",
        "element_name": "",
        "message": "No explicit Home guest-state page indicator or page-state validation element is present to support stronger guest-state verification beyond button visibility.",
        "suggested_fix": "Add a stable guest-state page indicator, shell container, title, or state-specific element if available."
      }
    ],
