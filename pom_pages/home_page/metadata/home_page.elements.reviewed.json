    "overall_quality": "low",
    "summary": "The draft artifact includes several noisy or workflow-unrelated elements and omits the core authenticated Home feature navigation controls required for downstream automation. Existing retained controls are only partially useful for workflow validation.",
    "issues": [
      {
        "severity": "critical",
        "type": "missing_element",
        "element_name": "",
        "message": "Required authenticated Home navigation controls for Vehicles On Site, Damage Claim, and Presell are missing from the approved page model.",
        "suggested_fix": "Add semantically named feature navigation controls using stable locators tied to the authenticated Home workflow."
      },
      {
        "severity": "high",
        "type": "naming",
        "element_name": "customersignup_button",
        "message": "Element appears unrelated to the documented Home authentication and feature-navigation workflow.",
        "suggested_fix": "Remove the element unless it is confirmed to represent a required workflow action."
      },
      {
        "severity": "high",
        "type": "naming",
        "element_name": "cleansurvey_button",
        "message": "Element naming is unsupported by the workflow context and lacks business relevance for authenticated Home navigation.",
        "suggested_fix": "Remove the element unless it directly maps to a validated workflow feature."
      },
      {
        "severity": "high",
        "type": "naming",
        "element_name": "sitesurvey_button",
        "message": "Element does not correspond to any required authenticated Home navigation action.",
        "suggested_fix": "Remove the element unless it is verified as part of the supported workflow."
      },
      {
        "severity": "high",
        "type": "duplicate",
        "element_name": "element_8",
        "message": "Generic anchor element duplicates the existing home navigation control and adds no automation value.",
        "suggested_fix": "Remove the duplicate generic anchor element and retain the semantic Home navigation control only."
      },
      {
        "severity": "high",
        "type": "locator",
        "element_name": "element_8",
        "message": "Locator xpath=//a is overly generic and likely to match multiple elements.",
        "suggested_fix": "Use a unique locator such as id or href-specific selector for the intended control."
      },
      {
        "severity": "medium",
        "type": "noise",
        "element_name": "background_content",
        "message": "Background container is layout-only and provides no meaningful automation or validation value.",
        "suggested_fix": "Remove the background container from the approved page model."
      },
      {
        "severity": "medium",
        "type": "naming",
        "element_name": "person_button",
        "message": "Element name is too generic and does not clearly reflect authentication or account access intent.",
        "suggested_fix": "Rename to user_profile_button or account_access_button for clearer automation semantics."
      },
